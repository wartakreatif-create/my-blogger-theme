<style>
/* --- GRID FOTO OVERFLOW PREMIUM (HEADLINE ONLY) --- */
.wc-foto-full {
    background: #ffffff;
    padding: 30px 0;
    margin: 20px 0;
    width: 100%;
    border-top: 1px solid #f0f0f0;
}

.wc-foto-header {
    max-width: 1200px;
    margin: 0 auto 20px;
    padding: 0 20px;
}

.wc-foto-scroll-wrapper {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 0 20px 20px 20px;
    gap: 20px;
    scrollbar-width: none;
}

.wc-foto-scroll-wrapper::-webkit-scrollbar { display: none; }

.wc-foto-item {
    flex: 0 0 23%; 
    min-width: 250px;
    scroll-snap-align: start;
    text-decoration: none;
    display: flex;
    flex-direction: column;
}

/* Gambar Full tanpa teks di bawahnya */
.wc-f-thumb {
    width: 100%;
    height: 180px; /* Sedikit lebih tinggi karena tidak ada teks */
    border-radius: 12px;
    overflow: hidden;
    background: #f5f5f5;
    transition: transform 0.3s ease;
}

.wc-f-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* Efek interaksi saat gambar disentuh */
.wc-foto-item:hover .wc-f-thumb {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
}

@media (max-width: 768px) {
    .wc-foto-item {
        flex: 0 0 70%;
        min-width: 240px;
    }
}
</style>

<div class="wc-foto-full">
    <div class="wc-foto-header">
        <h3 style="font-size: 20px; font-weight: 800; color: #333;">Foto</h3>
    </div>
    <div class="wc-foto-scroll-wrapper" id="foto-overflow-target">
        <!-- Foto Headline muncul di sini -->
    </div>
</div>

<script>
(function() {
    var labelKategori = "Headline"; // Poin 2: Ubah label menjadi Headline
    var totalBerita = 8; 
    
    fetch('/feeds/posts/summary/-/' + labelKategori + '?alt=json&max-results=' + totalBerita)
    .then(res => res.json())
    .then(json => {
        if (!json.feed.entry) {
            return fetch('/feeds/posts/summary?alt=json&max-results=' + totalBerita).then(res => res.json());
        }
        return json;
    })
    .then(json => {
        let html = '';
        json.feed.entry.forEach(post => {
            let title = post.title.$t;
            let link = post.link.find(l => l.rel === 'alternate').href;
            let thumb = post.media$thumbnail ? post.media$thumbnail.url.replace('s72-c', 's600') : 'https://placeholder.com';
            
            // Poin 1: Hanya berisi foto saja dalam tag <a>
            html += `
                <a href="${link}" class="wc-foto-item" title="${title}">
                    <div class="wc-f-thumb">
                        <img src="${thumb}" alt="${title}"/>
                    </div>
                </a>
            `;
        });
        document.getElementById('foto-overflow-target').innerHTML = html;
    });
})();
</script>
